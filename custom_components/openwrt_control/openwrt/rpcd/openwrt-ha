#!/bin/sh

. /usr/share/libubox/jshn.sh

SERVICE_VDS="vds_frolkin"

json_get() {
    local source="$1"
    local expr="$2"

    jsonfilter -s "$source" -e "$expr" 2>/dev/null | head -n 1
}

json_get_ipv4() {
    local source="$1"
    local ipv4

    ipv4="$(json_get "$source" '@["ipv4-address"][0].address')"
    [ -n "$ipv4" ] || ipv4="$(json_get "$source" '@.address[0].address')"
    printf '%s' "$ipv4"
}

normalize_bool() {
    [ "$1" = "true" ] && printf '1' || printf '0'
}

normalize_load() {
    local raw="${1:-0}"

    awk -v value="$raw" 'BEGIN { printf "%.2f", value / 65536 }'
}

safe_json() {
    "$@" 2>/dev/null || printf '{}'
}

service_script_running() {
    /etc/init.d/"$1" status 2>/dev/null | grep -qw running && printf '1' || printf '0'
}

passwall2_running() {
    pgrep -f '/usr/share/passwall2|/tmp/etc/passwall2' >/dev/null 2>&1 && printf '1' || printf '0'
}

xray_running() {
    pgrep -f '/tmp/etc/passwall2/bin/xray' >/dev/null 2>&1 && printf '1' || printf '0'
}

add_interface_object() {
    local name="$1"
    local status_json
    local up
    local device
    local ipv4

    status_json="$(safe_json ubus call "network.interface.${name}" status)"
    up="$(normalize_bool "$(json_get "$status_json" '@.up')")"
    device="$(json_get "$status_json" '@.l3_device')"
    [ -n "$device" ] || device="$(json_get "$status_json" '@.device')"
    ipv4="$(json_get_ipv4 "$status_json")"

    json_add_object "$name"
    json_add_boolean "up" "$up"
    [ -n "$device" ] && json_add_string "device" "$device" || json_add_string "device" ""
    [ -n "$ipv4" ] && json_add_string "ipv4" "$ipv4" || json_add_string "ipv4" ""
    json_close_object
}

render_status() {
    local board_json
    local info_json
    local hostname
    local model
    local kernel
    local version
    local uptime
    local load1_raw
    local load5_raw
    local load15_raw
    local mem_total
    local mem_free
    local mem_available
    local mem_buffered
    local mem_cached
    local load_json

    board_json="$(safe_json ubus call system board)"
    info_json="$(safe_json ubus call system info)"

    hostname="$(json_get "$board_json" '@.hostname')"
    model="$(json_get "$board_json" '@.model')"
    kernel="$(json_get "$board_json" '@.kernel')"
    version="$(json_get "$board_json" '@.release.version')"

    uptime="$(json_get "$info_json" '@.uptime')"
    load1_raw="$(json_get "$info_json" '@.load[0]')"
    load5_raw="$(json_get "$info_json" '@.load[1]')"
    load15_raw="$(json_get "$info_json" '@.load[2]')"

    mem_total="$(json_get "$info_json" '@.memory.total')"
    mem_free="$(json_get "$info_json" '@.memory.free')"
    mem_available="$(json_get "$info_json" '@.memory.available')"
    mem_buffered="$(json_get "$info_json" '@.memory.buffered')"
    mem_cached="$(json_get "$info_json" '@.memory.cached')"

    [ -n "$uptime" ] || uptime=0
    [ -n "$mem_total" ] || mem_total=0
    [ -n "$mem_free" ] || mem_free=0
    [ -n "$mem_available" ] || mem_available=$(( ${mem_free:-0} + ${mem_buffered:-0} + ${mem_cached:-0} ))
    load_json="$(printf '[%s,%s,%s]' "$(normalize_load "$load1_raw")" "$(normalize_load "$load5_raw")" "$(normalize_load "$load15_raw")")"

    json_init

    json_add_object "system"
    [ -n "$hostname" ] && json_add_string "hostname" "$hostname" || json_add_string "hostname" "OpenWrt"
    [ -n "$model" ] && json_add_string "model" "$model" || json_add_string "model" ""
    [ -n "$kernel" ] && json_add_string "kernel" "$kernel" || json_add_string "kernel" ""
    [ -n "$version" ] && json_add_string "version" "$version" || json_add_string "version" ""
    json_add_int "uptime" "$uptime"
    json_add_array "load"
    json_close_array
    json_add_object "memory"
    json_add_int "total" "$mem_total"
    json_add_int "free" "$mem_free"
    json_add_int "available" "$mem_available"
    json_close_object
    json_close_object

    json_add_object "interfaces"
    add_interface_object "lan"
    add_interface_object "wan"
    add_interface_object "$SERVICE_VDS"
    json_close_object

    json_add_object "services"
    json_add_object "passwall2"
    json_add_boolean "running" "$(passwall2_running)"
    json_close_object
    json_add_object "xray"
    json_add_boolean "running" "$(xray_running)"
    json_close_object
    json_add_object "dnsmasq"
    json_add_boolean "running" "$(service_script_running dnsmasq)"
    json_close_object
    json_close_object

    json_dump | sed "s/\"load\":\[\]/\"load\":$load_json/"
}

run_command_result() {
    local stdout_file
    local stderr_file
    local stdout_data
    local stderr_data
    local rc

    stdout_file="$(mktemp)"
    stderr_file="$(mktemp)"

    "$@" >"$stdout_file" 2>"$stderr_file"
    rc=$?

    stdout_data="$(cat "$stdout_file")"
    stderr_data="$(cat "$stderr_file")"

    rm -f "$stdout_file" "$stderr_file"

    json_init
    [ "$rc" -eq 0 ] && json_add_boolean "ok" "1" || json_add_boolean "ok" "0"
    json_add_int "rc" "$rc"
    json_add_string "stdout" "$stdout_data"
    json_add_string "stderr" "$stderr_data"
    json_dump
}

list_methods() {
    cat <<'EOF'
{
  "status": {},
  "restart_passwall2": {},
  "restart_dnsmasq": {},
  "reload_firewall": {},
  "restart_vds_openconnect": {},
  "reboot": {}
}
EOF
}

case "$1" in
    list)
        list_methods
    ;;
    call)
        case "$2" in
            status)
                render_status
            ;;
            restart_passwall2)
                run_command_result /etc/init.d/passwall2 restart
            ;;
            restart_dnsmasq)
                run_command_result /etc/init.d/dnsmasq restart
            ;;
            reload_firewall)
                run_command_result /etc/init.d/firewall reload
            ;;
            restart_vds_openconnect)
                run_command_result sh -c "ifdown ${SERVICE_VDS} && sleep 2 && ifup ${SERVICE_VDS}"
            ;;
            reboot)
                run_command_result reboot
            ;;
            *)
                exit 1
            ;;
        esac
    ;;
    *)
        exit 1
    ;;
esac
