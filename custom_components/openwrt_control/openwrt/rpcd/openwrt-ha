#!/bin/sh

. /usr/share/libubox/jshn.sh

[ -r /etc/openwrt-ha.conf ] && . /etc/openwrt-ha.conf

PLUGIN_VERSION="0.2.2"
SERVICE_OPENCONNECT="${OPENCONNECT_INTERFACE:-vpn}"
WAN_RATE_STATE_FILE="/tmp/openwrt-ha-wan-rate"

json_get() {
    local source="$1"
    local expr="$2"

    jsonfilter -s "$source" -e "$expr" 2>/dev/null | head -n 1
}

json_get_ipv4() {
    local source="$1"
    local ipv4

    ipv4="$(json_get "$source" '@["ipv4-address"][0].address')"
    [ -n "$ipv4" ] || ipv4="$(json_get "$source" '@.address[0].address')"
    printf '%s' "$ipv4"
}

normalize_bool() {
    [ "$1" = "true" ] && printf '1' || printf '0'
}

normalize_load() {
    local raw="${1:-0}"

    awk -v value="$raw" 'BEGIN { printf "%.6f", value / 65536 }'
}

safe_json() {
    "$@" 2>/dev/null || printf '{}'
}

read_uint_file() {
    local path="$1"

    [ -r "$path" ] || {
        printf '0'
        return
    }

    awk 'NR == 1 { value=$1 + 0; printf "%.0f", value; exit }' "$path" 2>/dev/null || printf '0'
}

calculate_rate_mbps() {
    local current="$1"
    local previous="$2"
    local seconds="$3"

    awk \
        -v current="$current" \
        -v previous="$previous" \
        -v seconds="$seconds" \
        'BEGIN {
            delta = current - previous
            if (seconds <= 0 || delta < 0) {
                printf "%.3f", 0
                exit
            }
            printf "%.3f", (delta * 8) / seconds / 1000000
        }'
}

read_cpu_sample() {
    awk '
        /^cpu / {
            idle = $5 + $6
            total = 0
            for (i = 2; i <= NF; i++) {
                total += $i
            }
            printf "%.0f %.0f", total, idle
            exit
        }
    ' /proc/stat 2>/dev/null
}

cpu_usage_percent() {
    local sample1
    local sample2
    local total1
    local idle1
    local total2
    local idle2

    sample1="$(read_cpu_sample)"
    sleep 0.4 2>/dev/null || usleep 400000 2>/dev/null || sleep 1
    sample2="$(read_cpu_sample)"

    set -- $sample1
    total1="${1:-0}"
    idle1="${2:-0}"

    set -- $sample2
    total2="${1:-0}"
    idle2="${2:-0}"

    awk \
        -v total1="$total1" \
        -v idle1="$idle1" \
        -v total2="$total2" \
        -v idle2="$idle2" \
        'BEGIN {
            total_delta = total2 - total1
            idle_delta = idle2 - idle1
            if (total_delta <= 0) {
                printf "%.1f", 0
                exit
            }

            usage = (1 - idle_delta / total_delta) * 100
            if (usage < 0) {
                usage = 0
            }
            if (usage > 100) {
                usage = 100
            }
            printf "%.1f", usage
        }'
}

service_script_running() {
    /etc/init.d/"$1" status 2>/dev/null | grep -qw running && printf '1' || printf '0'
}

passwall2_running() {
    pgrep -f '/usr/share/passwall2|/tmp/etc/passwall2' >/dev/null 2>&1 && printf '1' || printf '0'
}

xray_running() {
    pgrep -f '/tmp/etc/passwall2/bin/xray' >/dev/null 2>&1 && printf '1' || printf '0'
}

add_wan_statistics() {
    local device="$1"
    local rx_bytes
    local tx_bytes
    local now
    local prev_device
    local prev_ts
    local prev_rx
    local prev_tx
    local seconds
    local rx_mbps
    local tx_mbps

    rx_bytes="$(read_uint_file "/sys/class/net/${device}/statistics/rx_bytes")"
    tx_bytes="$(read_uint_file "/sys/class/net/${device}/statistics/tx_bytes")"
    now="$(date +%s 2>/dev/null)"
    [ -n "$now" ] || now=0

    if [ -r "$WAN_RATE_STATE_FILE" ]; then
        read -r prev_device prev_ts prev_rx prev_tx <"$WAN_RATE_STATE_FILE"
    fi

    if [ "$prev_device" = "$device" ] && [ -n "$prev_ts" ]; then
        seconds=$(( now - prev_ts ))
    else
        seconds=0
    fi

    rx_mbps="$(calculate_rate_mbps "$rx_bytes" "${prev_rx:-0}" "${seconds:-0}")"
    tx_mbps="$(calculate_rate_mbps "$tx_bytes" "${prev_tx:-0}" "${seconds:-0}")"

    printf '%s %s %s %s\n' "$device" "$now" "$rx_bytes" "$tx_bytes" >"$WAN_RATE_STATE_FILE" 2>/dev/null || true

    json_add_int "rx_bytes" "$rx_bytes"
    json_add_int "tx_bytes" "$tx_bytes"
    json_add_double "rx_mbps" "$rx_mbps"
    json_add_double "tx_mbps" "$tx_mbps"
}

add_interface_object() {
    local object_key="$1"
    local interface_name="$2"
    local include_name="${3:-0}"
    local include_counters="${4:-0}"
    local status_json
    local up
    local device
    local ipv4

    status_json="$(safe_json ubus call "network.interface.${interface_name}" status)"
    up="$(normalize_bool "$(json_get "$status_json" '@.up')")"
    device="$(json_get "$status_json" '@.l3_device')"
    [ -n "$device" ] || device="$(json_get "$status_json" '@.device')"
    ipv4="$(json_get_ipv4 "$status_json")"

    json_add_object "$object_key"
    [ "$include_name" = "1" ] && json_add_string "name" "$interface_name"
    json_add_boolean "up" "$up"
    [ -n "$device" ] && json_add_string "device" "$device" || json_add_string "device" ""
    [ -n "$ipv4" ] && json_add_string "ipv4" "$ipv4" || json_add_string "ipv4" ""

    if [ "$include_counters" = "1" ] && [ -n "$device" ]; then
        add_wan_statistics "$device"
    fi

    json_close_object
}

render_status() {
    local board_json
    local info_json
    local hostname
    local model
    local kernel
    local version
    local uptime
    local load1_raw
    local load5_raw
    local load15_raw
    local mem_total
    local mem_free
    local mem_available
    local mem_buffered
    local mem_cached
    local cpu_usage

    board_json="$(safe_json ubus call system board)"
    info_json="$(safe_json ubus call system info)"
    cpu_usage="$(cpu_usage_percent)"

    hostname="$(json_get "$board_json" '@.hostname')"
    model="$(json_get "$board_json" '@.model')"
    kernel="$(json_get "$board_json" '@.kernel')"
    version="$(json_get "$board_json" '@.release.version')"

    uptime="$(json_get "$info_json" '@.uptime')"
    load1_raw="$(json_get "$info_json" '@.load[0]')"
    load5_raw="$(json_get "$info_json" '@.load[1]')"
    load15_raw="$(json_get "$info_json" '@.load[2]')"

    mem_total="$(json_get "$info_json" '@.memory.total')"
    mem_free="$(json_get "$info_json" '@.memory.free')"
    mem_available="$(json_get "$info_json" '@.memory.available')"
    mem_buffered="$(json_get "$info_json" '@.memory.buffered')"
    mem_cached="$(json_get "$info_json" '@.memory.cached')"

    [ -n "$uptime" ] || uptime=0
    [ -n "$mem_total" ] || mem_total=0
    [ -n "$mem_free" ] || mem_free=0
    [ -n "$mem_available" ] || mem_available=$(( ${mem_free:-0} + ${mem_buffered:-0} + ${mem_cached:-0} ))

    json_init

    json_add_object "plugin"
    json_add_string "version" "$PLUGIN_VERSION"
    json_close_object

    json_add_object "system"
    [ -n "$hostname" ] && json_add_string "hostname" "$hostname" || json_add_string "hostname" "OpenWrt"
    [ -n "$model" ] && json_add_string "model" "$model" || json_add_string "model" ""
    [ -n "$kernel" ] && json_add_string "kernel" "$kernel" || json_add_string "kernel" ""
    [ -n "$version" ] && json_add_string "version" "$version" || json_add_string "version" ""
    json_add_int "uptime" "$uptime"
    json_add_object "cpu"
    json_add_double "usage_percent" "$cpu_usage"
    json_close_object
    json_add_array "load"
    json_add_double "" "$(normalize_load "$load1_raw")"
    json_add_double "" "$(normalize_load "$load5_raw")"
    json_add_double "" "$(normalize_load "$load15_raw")"
    json_close_array
    json_add_object "memory"
    json_add_int "total" "$mem_total"
    json_add_int "free" "$mem_free"
    json_add_int "available" "$mem_available"
    json_close_object
    json_close_object

    json_add_object "interfaces"
    add_interface_object "lan" "lan"
    add_interface_object "wan" "wan" "0" "1"
    add_interface_object "openconnect" "$SERVICE_OPENCONNECT" "1"
    json_close_object

    json_add_object "services"
    json_add_object "passwall2"
    json_add_boolean "running" "$(passwall2_running)"
    json_close_object
    json_add_object "xray"
    json_add_boolean "running" "$(xray_running)"
    json_close_object
    json_add_object "dnsmasq"
    json_add_boolean "running" "$(service_script_running dnsmasq)"
    json_close_object
    json_close_object

    json_dump
}

run_command_result() {
    local stdout_file
    local stderr_file
    local stdout_data
    local stderr_data
    local rc

    stdout_file="$(mktemp)"
    stderr_file="$(mktemp)"

    "$@" >"$stdout_file" 2>"$stderr_file"
    rc=$?

    stdout_data="$(cat "$stdout_file")"
    stderr_data="$(cat "$stderr_file")"

    rm -f "$stdout_file" "$stderr_file"

    json_init
    [ "$rc" -eq 0 ] && json_add_boolean "ok" "1" || json_add_boolean "ok" "0"
    json_add_int "rc" "$rc"
    json_add_string "stdout" "$stdout_data"
    json_add_string "stderr" "$stderr_data"
    json_dump
}

list_methods() {
    cat <<'EOF'
{
  "status": {},
  "restart_passwall2": {},
  "restart_dnsmasq": {},
  "reload_firewall": {},
  "restart_openconnect": {},
  "reboot": {}
}
EOF
}

case "$1" in
    list)
        list_methods
    ;;
    call)
        case "$2" in
            status)
                render_status
            ;;
            restart_passwall2)
                run_command_result /etc/init.d/passwall2 restart
            ;;
            restart_dnsmasq)
                run_command_result /etc/init.d/dnsmasq restart
            ;;
            reload_firewall)
                run_command_result /etc/init.d/firewall reload
            ;;
            restart_openconnect)
                run_command_result sh -c "ifdown \"$SERVICE_OPENCONNECT\" && sleep 2 && ifup \"$SERVICE_OPENCONNECT\""
            ;;
            reboot)
                run_command_result reboot
            ;;
            *)
                exit 1
            ;;
        esac
    ;;
    *)
        exit 1
    ;;
esac
