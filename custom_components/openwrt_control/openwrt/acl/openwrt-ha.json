{
  "openwrt-ha": {
    "description": "Home Assistant OpenWrt Control",
    "read": {
      "ubus": {
        "openwrt.ha": [
          "status"
        ]
      }
    },
    "write": {
      "ubus": {
        "openwrt.ha": [
          "restart_passwall2",
          "restart_dnsmasq",
          "reload_firewall",
          "restart_openconnect",
          "restart_vds_openconnect",
          "reboot"
        ]
      }
    }
  }
}
