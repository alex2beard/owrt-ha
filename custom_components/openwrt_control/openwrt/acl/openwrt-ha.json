{
  "openwrt-ha": {
    "description": "Home Assistant OpenWrt Control",
    "read": {
      "ubus": {
        "openwrt.ha": [
          "status"
        ],
        "system": [
          "board",
          "info"
        ],
        "network.interface": [
          "dump"
        ],
        "network.interface.lan": [
          "status"
        ],
        "network.interface.wan": [
          "status"
        ],
        "network.interface.vds_frolkin": [
          "status"
        ]
      }
    },
    "write": {
      "ubus": {
        "openwrt.ha": [
          "restart_passwall2",
          "restart_dnsmasq",
          "reload_firewall",
          "restart_vds_openconnect",
          "reboot"
        ]
      }
    }
  }
}
